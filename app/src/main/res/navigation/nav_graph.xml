<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/noteListFragment">

    <fragment
        android:id="@+id/noteListFragment"
        android:name="com.jckent.notetaker.ui.notes.NoteListFragment"
        android:label="Notes"
        tools:layout="@layout/fragment_note_list">
        <action
            android:id="@+id/action_noteList_to_noteEditor"
            app:destination="@id/noteEditorFragment" />
    </fragment>

    <fragment
        android:id="@+id/noteEditorFragment"
        android:name="com.jckent.notetaker.ui.editor.NoteEditorFragment"
        android:label="Edit Note"
        tools:layout="@layout/fragment_note_editor">
        <argument
            android:name="noteId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="audioPath"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/recordingFragment"
        android:name="com.jckent.notetaker.ui.recording.RecordingFragment"
        android:label="Record"
        tools:layout="@layout/fragment_recording">
        <action
            android:id="@+id/action_recording_to_noteEditor"
            app:destination="@id/noteEditorFragment" />
    </fragment>

</navigation>
